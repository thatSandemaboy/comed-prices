# ComEd Hourly Pricing App - Environment Variables

# Database path (defaults to ./data/comed.db)
DATABASE_PATH=./data/comed.db

# App URL (used for magic links and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend API Key for email notifications
# Get one at https://resend.com
RESEND_API_KEY=

# Email address to send from (must be verified in Resend)
FROM_EMAIL=alerts@resend.dev

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
